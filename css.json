      "ultrathin": { "hex": "#1c1c1e", "opacity": "0.42", "blur": "12px" },
      "thin": { "hex": "#1c1c1e", "opacity": "0.55", "blur": "16px" },
      "regular": { "hex": "#1c1c1e", "opacity": "0.68", "blur": "22px" },
      "thick": { "hex": "#1c1c1e", "opacity": "0.82", "blur": "30px" },
      "chrome": { "hex": "#161618", "opacity": "0.84", "blur": "20px" },
      "border": { "hex": "#ffffff", "opacity": "0.10" },
      "edge": { "hex": "#ffffff", "opacity": "0.12" }
    },
    "rules": [
      "面积越大、越结构化的面材质越厚，阴影越深",
      "两层浅材质禁止叠放；叠放时上层用 thick/chrome 或实底",
      "材质面文字用 vibrancy（label 半透明色 + 稍重字重），彩色内容放实底层",
      "模态 = 材质 + scrim；并行面板 = 材质 + 位移，不加遮罩",
      "prefers-reduced-transparency / prefers-contrast 下退化为实底"
    ]
  },
  "motion": {
    "spring": {
      "default": { "damping": 1.0, "response": 0.4, "usage": "常规位移、归位" },
      "snappy": { "damping": 1.0, "response": 0.3, "usage": "小控件、popover" },
      "bouncy": { "damping": 0.8, "response": 0.4, "usage": "仅限带动量的交互（flick/拖拽释放）" },
      "sheet": { "damping": 0.8, "response": 0.3, "usage": "抽屉/底部面板" }
    },
    "duration": {
      "instant": "100ms",
      "fast": "200ms",
      "base": "300ms",
      "slow": "450ms"
    },
    "easing": {
      "ease-out": "cubic-bezier(0.25, 1, 0.5, 1)",
      "ease-in": "cubic-bezier(0.5, 0, 0.75, 0)",
      "ease-in-out": "cubic-bezier(0.45, 0, 0.55, 1)"
    },
    "pressScale": 0.97,
    "projection": { "decelerationRate": 0.998, "formula": "(v/1000) * rate / (1 - rate)" },
    "rubberband": { "constant": 0.55, "formula": "(overshoot * dimension * c) / (dimension + c * |overshoot|)" }
  }
}
